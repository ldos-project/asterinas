#!/usr/bin/env python3
"""Repo-root launcher for the Mariposa CLI.

Lets you run the CLI in-tree without installing it: ``./mariposa oqueues list``.
Puts the ``mariposa-cli`` project on sys.path, then hands off to its entry
point. Once ``mariposa-cli`` is pip-installed, the ``mariposa`` console script
does the same thing from anywhere.
"""

import os
import sys

sys.path.insert(
    0, os.path.join(os.path.dirname(os.path.abspath(__file__)), "mariposa-cli")
)

from mariposa_cli.cli import main

if __name__ == "__main__":
    sys.exit(main())
